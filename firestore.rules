rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'blessedt.BJ@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }

    // User Profiles
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.displayName is string && data.displayName.size() <= 100 &&
               data.role in ['rider', 'driver', 'admin'] &&
               (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 512)) &&
               (data.get('rating', null) == null || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
               (data.get('totalRatings', null) == null || data.totalRatings is number);
      }

      // riders/drivers need to see each other's profiles for rides
      // Allow any signed in user to get a profile (needed for identification in ride requests)
      // We check for isOwner for listing or use isOwner for get to be extra safe if needed, 
      // but standard "get" for identification is usually fine as long as PII is separate.
      allow get: if isSignedIn();
      allow list: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                       isValidUserProfile(incoming()) && 
                       incoming().keys().hasAll(['displayName', 'role', 'createdAt']) &&
                       (incoming().keys().size() == 3 || (incoming().keys().hasAll(['photoURL']) && incoming().keys().size() == 4));

      allow update: if (isOwner(userId) && 
                        isValidUserProfile(incoming()) && 
                        (existing().get('role', null) == null || incoming().role == existing().role) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role', 'updatedAt', 'totalRatings', 'rating', 'phone', 'vehicle', 'onboarded'])) ||
                       isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.rideId is string && isValidId(data.rideId) &&
               data.senderId == request.auth.uid &&
               data.text is string && data.text.size() <= 1000 &&
               data.createdAt == request.time;
      }

      allow list, get: if isSignedIn(); // Simplified for now, complex checks often fail on list
      
      allow create: if isSignedIn() && isValidChat(incoming());
    }

    // User Private Info
    match /users/{userId}/private/info {
       function isValidPrivate(data) {
         return data.email is string && data.email.size() <= 128;
       }
       allow read: if isOwner(userId) || isAdmin();
       allow write: if (isOwner(userId) && isValidPrivate(incoming())) || isAdmin();
    }

    // Rides
    match /rides/{rideId} {
       function isValidRide(data) {
         return data.riderId is string && isValidId(data.riderId) &&
                data.status in ['requested', 'accepted', 'arrived', 'started', 'completed', 'cancelled'] &&
                data.pickup is map && data.destination is map &&
                data.pickup.lat is number && data.pickup.lng is number &&
                data.destination.lat is number && data.destination.lng is number &&
                data.price is number && 
                (data.get('surgeMultiplier', null) == null || data.surgeMultiplier is number);
       }

       allow list: if isSignedIn() && (
         resource.data.riderId == request.auth.uid || 
         resource.data.driverId == request.auth.uid || 
         (resource.data.status == 'requested' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver') ||
         isAdmin()
       );
       
       allow get: if isSignedIn() && (
         resource.data.riderId == request.auth.uid || 
         resource.data.driverId == request.auth.uid || 
         resource.data.status == 'requested' || 
         isAdmin()
       );
       
       allow create: if isSignedIn() && 
                        incoming().riderId == request.auth.uid &&
                        incoming().status == 'requested' &&
                        isValidRide(incoming()) &&
                        incoming().createdAt == request.time;

       allow update: if (isSignedIn() && (
         isAdmin() ||
         (isValidRide(incoming()) && (
           // Rider can cancel
           (isOwner(existing().riderId) && 
            incoming().status == 'cancelled' && 
            existing().status == 'requested' &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
           // Driver can accept
           (incoming().driverId == request.auth.uid &&
            existing().status == 'requested' &&
            incoming().status == 'accepted' &&
            incoming().diff(existing()).affectedKeys().hasOnly(['driverId', 'status', 'updatedAt'])) ||
           // Driver update status
           (existing().driverId == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
         ))
       ));
    }

    // Driver Status
    match /driverStatus/{driverId} {
      function isValidDriverStatus(data) {
        return data.driverId == driverId &&
               data.location is map &&
               data.location.lat is number && data.location.lng is number &&
               data.status in ['online', 'offline', 'busy'] &&
               data.lastUpdate == request.time;
      }

      allow read: if isSignedIn();
      allow write: if (isOwner(driverId) && isValidDriverStatus(incoming())) || isAdmin();
    }
  }
}
